{
  "packId": "french:quote-drills:core",
  "languageId": "french",
  "contentFamilyId": "quote-drills",
  "tier": "core",
  "version": "2026-03-17-public-corpus-v3",
  "entryCount": 96,
  "entries": [
    {
      "text": "\" demanda un autre juré.",
      "signature": ".\"adeéjmnrtu",
      "openingToken": "demanda",
      "tokenCount": 4,
      "difficultyBand": "developing"
    },
    {
      "text": "Enlève-moi ça bien vite.",
      "signature": "-.abçeèilmnotv",
      "openingToken": "enlève-moi",
      "tokenCount": 4,
      "difficultyBand": "developing"
    },
    {
      "text": "la voilà qui dégringole.",
      "signature": ".aàdeégilnoqruv",
      "openingToken": "la",
      "tokenCount": 4,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Pour trouver des pommes!",
      "signature": "!\"demoprstuv",
      "openingToken": "pour",
      "tokenCount": 4,
      "difficultyBand": "developing"
    },
    {
      "text": "la Duchesse, la Duchesse!",
      "signature": ",!acdehlsu",
      "openingToken": "la",
      "tokenCount": 4,
      "difficultyBand": "developing"
    },
    {
      "text": "mes pauvres petits pieds!",
      "signature": "!adeimprstuv",
      "openingToken": "mes",
      "tokenCount": 4,
      "difficultyBand": "developing"
    },
    {
      "text": "Voilà la grande question.",
      "signature": ".aàdegilnoqrstuv",
      "openingToken": "voilà",
      "tokenCount": 4,
      "difficultyBand": "developing"
    },
    {
      "text": "Aux Antipathies, je crois.",
      "signature": ",.acehijnoprstux",
      "openingToken": "aux",
      "tokenCount": 4,
      "difficultyBand": "developing"
    },
    {
      "text": "\" lui crièrent les soldats.",
      "signature": ".\"acdeèilnorstu",
      "openingToken": "lui",
      "tokenCount": 4,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Comment faire pour entrer?",
      "signature": "?\"acefimnoprtu",
      "openingToken": "comment",
      "tokenCount": 4,
      "difficultyBand": "developing"
    },
    {
      "text": "Qu'on lui coupe la tête!",
      "signature": "!'aceêilnopqtu",
      "openingToken": "qu'on",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\" demanda le Roi à Alice.",
      "signature": ".\"aàcdeilmnor",
      "openingToken": "demanda",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "La Reine sourit et passa.",
      "signature": ".aeilnoprstu",
      "openingToken": "la",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "–Ne le faites pas engouer.",
      "signature": "–.aefgilnoprstu",
      "openingToken": "ne",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\" se fit entendre au loin.",
      "signature": ".\"adefilnorstu",
      "openingToken": "se",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "C'est cela qui sera drôle!",
      "signature": "!'acdeilôqrstu",
      "openingToken": "c'est",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "C'est cela qui sera drôle.",
      "signature": ".'acdeilôqrstu",
      "openingToken": "c'est",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "Le bébé grogna de nouveau.",
      "signature": ".abdeéglnoruv",
      "openingToken": "le",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "ma robe et mes moustaches!",
      "signature": "!abcehmorstu",
      "openingToken": "ma",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\" se hasarda de dire Alice.",
      "signature": ".\"acdehilrs",
      "openingToken": "se",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\"La Reine va nous entendre!",
      "signature": "!\"adeilnorstuv",
      "openingToken": "la",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Mais qui donnera les prix?",
      "signature": "?\"adeilmnopqrsux",
      "openingToken": "mais",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Quel est donc son chagrin?",
      "signature": "?\"acdeghilnoqrstu",
      "openingToken": "quel",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "Avant de faire un plongeon.",
      "signature": ".adefgilnoprtuv",
      "openingToken": "avant",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "Ça bouche toute la fenêtre.",
      "signature": ".abcçeêfhlnortu",
      "openingToken": "ça",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "Faire la révérence en l'air!",
      "signature": "!'aceéfilnrv",
      "openingToken": "faire",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "je vous demande bien pardon!",
      "signature": "!abdeijmnoprsuv",
      "openingToken": "je",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "mais quelle énigme que cela!",
      "signature": "!aceégilmnqsu",
      "openingToken": "mais",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "Tout le monde regarda Alice.",
      "signature": ".acdegilmnortu",
      "openingToken": "tout",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Saisissez ce Loir au collet!",
      "signature": "!\"aceilorstuz",
      "openingToken": "saisissez",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "On ne gaspille pas quelqu'un.",
      "signature": ".'aegilnopqsu",
      "openingToken": "on",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\" une fois environ par minute.",
      "signature": ".\"aefimnoprstuv",
      "openingToken": "une",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Je rapetisse donc de nouveau?",
      "signature": "?\"acdeijnoprstuv",
      "openingToken": "je",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Maintenant ça va mieux aller.",
      "signature": ".\"açeilmnrtuvx",
      "openingToken": "maintenant",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "que d'enfantillages je dis là!",
      "signature": "!'aàdefgijlnqstu",
      "openingToken": "que",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "Toutes revinrent d'eux à vous.",
      "signature": ".'àdeinorstuvx",
      "openingToken": "toutes",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "–Cette question est trop sotte!",
      "signature": "–!ceinopqrstu",
      "openingToken": "cette",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Comment faire pour nous sécher?",
      "signature": "?\"aceéfhimnoprstu",
      "openingToken": "comment",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "J'allais oublier de le demander.",
      "signature": ".'abdeijlmnorsu",
      "openingToken": "j'allais",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "Alice se trouva fort embarrassée.",
      "signature": ".abceéfilmorstuv",
      "openingToken": "alice",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "\" demanda Alice un peu timidement.",
      "signature": ".\"acdeilmnptu",
      "openingToken": "demanda",
      "tokenCount": 5,
      "difficultyBand": "developing"
    },
    {
      "text": "et cela en moins de rien!",
      "signature": "!acdeilmnorst",
      "openingToken": "et",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Coupez la tête à ce Loir!",
      "signature": "!\"aàceêiloprtuz",
      "openingToken": "coupez",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Mettez ce Loir à la porte!",
      "signature": "!aàceilmoprtz",
      "openingToken": "mettez",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "\" dit le Chat à voix basse.",
      "signature": ".\"aàbcdehilostvx",
      "openingToken": "dit",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "'Que je ne savais pas nager!",
      "signature": "!'aegijnpqrsuv",
      "openingToken": "'que",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Et où donc sont mes épaules?",
      "signature": "?\"acdeélmnopstuù",
      "openingToken": "et",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Je suis fou, vous êtes folle.",
      "signature": ",.eêfijlostuv",
      "openingToken": "je",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Je dois être changée en Mabel!",
      "signature": "!abcdeéêghijlmnorst",
      "openingToken": "je",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "–Mais je suis déjà bien grande!",
      "signature": "–!aàbdeégijmnrsu",
      "openingToken": "mais",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Enfin tout rentra dans le calme.",
      "signature": ".acdefilmnorstu",
      "openingToken": "enfin",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Et c'est vraiment par trop fort!",
      "signature": "!'acefimnoprstv",
      "openingToken": "et",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Le Lapin Blanc mit ses lunettes.",
      "signature": ".abceilmnpstu",
      "openingToken": "le",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Le Loir ouvrit lentement les yeux.",
      "signature": ".eilmnorstuvxy",
      "openingToken": "le",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Vous en étiez au cinquième détour.",
      "signature": ".\"acdeéèimnoqrstuvz",
      "openingToken": "vous",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Le Valet secoua la tête tristement.",
      "signature": ".aceêilmnorstuv",
      "openingToken": "le",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Le Chat grimaça en apercevant Alice.",
      "signature": ".acçeghilmnprtv",
      "openingToken": "le",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "pour partage, Quoi de plus précieux?",
      "signature": ",?acdeégilopqrstux",
      "openingToken": "pour",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "\" redemanda Alice en élevant la voix.",
      "signature": ".\"acdeéilmnortvx",
      "openingToken": "redemanda",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Alice croisa les mains et commença: .",
      "signature": ":.acçeilmnorst",
      "openingToken": "alice",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "je puis vous en fournir quelques-uns!",
      "signature": "-!efijlnopqrsuv",
      "openingToken": "je",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Le premier témoin était le Chapelier.",
      "signature": ".aceéhilmnoprt",
      "openingToken": "le",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Où pourrais-je bien les avoir perdus?",
      "signature": "-?abdeijlnoprsuùv",
      "openingToken": "où",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "vous parlez de faire des révolutions!",
      "signature": "!adeéfilnoprstuvz",
      "openingToken": "vous",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Il est toujours six heures maintenant.",
      "signature": ".aehijlmnorstux",
      "openingToken": "il",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Le Chapelier secoua tristement la tête.",
      "signature": ".aceêhilmnoprstu",
      "openingToken": "le",
      "tokenCount": 6,
      "difficultyBand": "developing"
    },
    {
      "text": "Alors on les jeta à la mer.",
      "signature": ".aàejlmnorst",
      "openingToken": "alors",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Il se fit un silence de mort.",
      "signature": ".cdefilmnorstu",
      "openingToken": "il",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Ce matin je n'ai rien à faire.",
      "signature": ".'aàcefijmnrt",
      "openingToken": "ce",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Cela lui faisait bien un peu peur.",
      "signature": ".abcefilnprstu",
      "openingToken": "cela",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Dinah est si douce et si gentille.",
      "signature": ".acdeghilnostu",
      "openingToken": "dinah",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "que de leçons on me fera apprendre!",
      "signature": "!açdeflmnopqrsu",
      "openingToken": "que",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\" Puis elle ouvrit la porte et entra.",
      "signature": ".\"aeilnoprstuv",
      "openingToken": "puis",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Quel long somme vous venez de faire!",
      "signature": "!\"adefgilmnoqrsuvz",
      "openingToken": "quel",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "je voudrais bien n'avoir pas tant bu!",
      "signature": "!'abdeijnoprstuv",
      "openingToken": "je",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Silence dans le cercle, je vous prie.",
      "signature": ",.acdeijlnoprsuv",
      "openingToken": "silence",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\" hurla la Reine de toutes ses forces.",
      "signature": ".\"acdefhilnorstu",
      "openingToken": "hurla",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Alice pensa que cela ne prouvait rien.",
      "signature": ".aceilnopqrstuv",
      "openingToken": "alice",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Alors ils ne purent plus l'en retirer.",
      "signature": ".'aeilnoprstu",
      "openingToken": "alors",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\" dit celui qui avait parlé le premier.",
      "signature": ".\"acdeéilmpqrtuv",
      "openingToken": "dit",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\" Et le bourreau partit comme un trait.",
      "signature": ".\"abceilmnoprtu",
      "openingToken": "et",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Il se fit quelques instants de silence.",
      "signature": ".acdefilnqstu",
      "openingToken": "il",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Jetez toujours le blâme sur les autres!",
      "signature": "!aâbejlmorstuz",
      "openingToken": "jetez",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\" hurla le Griffon de toutes ses forces.",
      "signature": ".\"acdefghilnorstu",
      "openingToken": "hurla",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Alors elle devrait porter le numéro Un.",
      "signature": ".\"adeéilmnoprstuv",
      "openingToken": "alors",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\" Ici le sommeil commença à gagner Alice.",
      "signature": ".\"aàcçegilmnors",
      "openingToken": "ici",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "–Je vais tâcher de réciter Maître Corbeau.",
      "signature": "–.aâbcdeéhiîjmorstuv",
      "openingToken": "je",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Vous feriez perdre patience à une huître.",
      "signature": ".\"aàcdefhiînoprstuvz",
      "openingToken": "vous",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Elle resta donc tranquille sans rien dire.",
      "signature": ".acdeilnoqrstu",
      "openingToken": "elle",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Le Chapelier rompit le silence le premier.",
      "signature": ".acehilmnoprst",
      "openingToken": "le",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "Mais peu importe la table de multiplication.",
      "signature": ".abcdeilmnoprstu",
      "openingToken": "mais",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\" Ce qui produisit encore un profond silence.",
      "signature": ".\"cdefilnopqrstu",
      "openingToken": "ce",
      "tokenCount": 7,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Que de châssis il doit y avoir là!",
      "signature": "!\"aàâcdehiloqrstuvy",
      "openingToken": "que",
      "tokenCount": 8,
      "difficultyBand": "developing"
    },
    {
      "text": "A ces mots son pied glissa, et flac!",
      "signature": ",!acdefgilmnopst",
      "openingToken": "a",
      "tokenCount": 8,
      "difficultyBand": "developing"
    },
    {
      "text": "\"Tous les mots ne sont pas les mêmes.",
      "signature": ".\"aeêlmnopstu",
      "openingToken": "tous",
      "tokenCount": 8,
      "difficultyBand": "developing"
    },
    {
      "text": "il n'y a pas moyen de les satisfaire.",
      "signature": ".'adefilmnoprsty",
      "openingToken": "il",
      "tokenCount": 8,
      "difficultyBand": "developing"
    }
  ]
}